# CXone application registration (from NICE developer portal)
CXONE_CLIENT_ID=
CXONE_CLIENT_SECRET=

# API user access key (Admin > Employees > Access Keys)
CXONE_ACCESS_KEY_ID=
CXONE_ACCESS_KEY_SECRET=

# Optional: override discovered API host (e.g. https://api-na1.niceincontact.com)
# CXONE_API_BASE_URL=

# Interaction Analytics path — confirm via developer portal "Try it out"
CXONE_IA_API_PATH=/interaction-analytics-gateway/v2

# Interaction Analytics list/pagination (date range is filtered client-side)
CXONE_IA_DATE_FIELD=startTime
CXONE_IA_ORDER=desc
CXONE_IA_PAGE_SIZE=100
# Optional mediaType filter on list API (empty = all types)
CXONE_PHONE_MEDIA_TYPES=PhoneCall
# Concurrent transcript fetches when using --enrich-transcripts (default 8)
# CXONE_TRANSCRIPT_FETCH_CONCURRENCY=8

# Zendesk API token (Admin > Apps and integrations > APIs)
ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=
# Optional override, e.g. https://yourcompany.zendesk.com
# ZENDESK_API_BASE_URL=
# Promoted custom field columns (copy from config/zendesk_field_map.json.example)
# ZENDESK_FIELD_MAP_PATH=config/zendesk_field_map.json

# CXone ↔ Zendesk link rules for Step 3 (copy from config/cxone_zendesk_link.json.example)
# CXONE_ZENDESK_LINK_PATH=config/cxone_zendesk_link.json

# Step 4 analysis (copy from config/interaction_summary.json.example)
# INTERACTION_SUMMARY_CONFIG_PATH=config/interaction_summary.json
# Copy config/disposition_label_map.json.example -> config/disposition_label_map.json

# Step 4 LLM recommendations (optional; OpenAI-compatible API)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1

# PostgreSQL (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+psycopg://orchestration:orchestration@localhost:5433/orchestration

# --- Hosted chatbot (Railway) — see docs/CHATBOT_RAILWAY.md ---
# CHATBOT_USERNAME=analytics
# CHATBOT_PASSWORD=
# CHATBOT_USERS=user1:pass1,user2:pass2
# Sync from your PC: public TCP proxy URL (NOT postgres.railway.internal)
# TARGET_DATABASE_URL=postgresql://postgres:...@....proxy.rlwy.net:PORT/railway
